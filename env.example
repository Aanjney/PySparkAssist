# Copy to .env and edit.
#
# Paths: use ./data/... when running from the repo root (venv / ingest).
#        Use /app/data/... in Docker when the host data/ dir is mounted at /app/data.

# --- Required ---
GROQ_API_KEY=replace_with_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# --- Paths (defaults below match config.py) ---
QDRANT_PATH=./data/qdrant
SQLITE_PATH=./data/graph.db
GROQ_LIMITS_PATH=./data/groq_limits.json
RAW_DATA_PATH=./data/raw

# --- Optional (omit to use defaults in config.py) ---
# GROQ_TEMPERATURE=0.3
# GROQ_MAX_TOKENS=2048
# RATE_LIMIT_RPM=20
# RELEVANCE_THRESHOLD=0.35
# GROQ_LIMITS_STARTUP_PROBE=true
